{
  "name": "vite-vue3-h5-ssr",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@10.32.1",
  "author": "lincenying <lincenying@qq.com>",
  "scripts": {
    "prepare[-del]": "npx simple-git-hooks",
    "serve": "nodemon --watch ./server.dev.ts --exec tsx ./server.dev.ts",
    "build": "npm run build:client && npm run build:server && npm run build:server:entry",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "cross-env VITE_APP_SSR=true vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:server:entry": "tsup --entry.server server.prod.ts --format esm --target es2020",
    "start": "cross-env NODE_ENV=production node ./dist/server.js",
    "generate": "vite build --ssrManifest --outDir dist/static && npm run build:server && tsx ./prerender.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "vue-tsc -b --noEmit",
    "lint:css": "stylelint '**/*.{css,scss}' --fix",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@lincy/utils": "catalog:prod",
    "@unhead/ssr": "catalog:prod",
    "@unhead/vue": "catalog:prod",
    "@vue/server-renderer": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "axios": "catalog:prod",
    "compression": "catalog:prod",
    "cookie-parser": "catalog:prod",
    "ejs": "catalog:prod",
    "express": "catalog:prod",
    "http-proxy-middleware": "catalog:prod",
    "lodash": "catalog:prod",
    "lru-cache": "catalog:prod",
    "md5": "catalog:prod",
    "morgan": "catalog:prod",
    "pinia": "catalog:prod",
    "qs": "catalog:prod",
    "request-ip": "catalog:prod",
    "serve-static": "catalog:prod",
    "store2": "catalog:prod",
    "vant": "catalog:prod",
    "vue": "catalog:prod",
    "vue-router": "catalog:prod"
  },
  "devDependencies": {
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/compression": "catalog:types",
    "@types/cookie-parser": "catalog:types",
    "@types/ejs": "catalog:types",
    "@types/express": "catalog:types",
    "@types/morgan": "catalog:types",
    "@types/node": "catalog:types",
    "@types/request-ip": "catalog:types",
    "@unocss/eslint-plugin": "catalog:lint",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue-macros/volar": "catalog:dev",
    "baseline-browser-mapping": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "lint-staged": "catalog:dev",
    "mockjs": "catalog:dev",
    "nodemon": "catalog:dev",
    "postcss": "catalog:dev",
    "postcss-px-to-viewport-8-plugin": "catalog:dev",
    "sass-embedded": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "stylelint": "catalog:lint",
    "tsup": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-inspect": "catalog:dev",
    "vite-plugin-mock": "catalog:dev",
    "vite-plugin-progress": "catalog:dev",
    "vue-macros": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged[-del]": {
    "*.{[jt]s?(x),vue,md}": [
      "eslint --fix"
    ],
    "*.{css,scss}": "stylelint --fix --allow-empty-input"
  }
}
